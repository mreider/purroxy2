{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Purroxy",
  "version": "0.1.0",
  "identifier": "com.purroxy.desktop",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Purroxy v2.0",
        "width": 960,
        "height": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": ["icons/icon.png"]
  }
}
